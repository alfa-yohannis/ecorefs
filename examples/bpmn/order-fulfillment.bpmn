<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    id="Definitions_OrderFulfillment"
    targetNamespace="http://ecorefs.org/examples/bpmn/order-fulfillment">

  <!--
    Process.supports is a real BPMN2 non-containment EReference (Process -> Process).
    In EMF XMI it serializes as a child element using href, so EMF will automatically
    download the referenced resource from IPFS and resolve the fragment.
  -->
  <bpmn2:process id="OrderFulfillmentProcess" name="Order Fulfillment Process" isExecutable="false">

    <bpmn2:supports href="ipfs://QmVgQCkKWWbmMP7DqjWK6rTEMabcr6iUXGbJHQNvAFdnv9#//LoanApplicationProcess"/>

    <bpmn2:startEvent id="StartEvent_1" name="Order Placed">
      <bpmn2:outgoing>Flow_1</bpmn2:outgoing>
    </bpmn2:startEvent>

    <bpmn2:task id="Task_CheckInventory" name="Check Inventory">
      <bpmn2:incoming>Flow_1</bpmn2:incoming>
      <bpmn2:outgoing>Flow_2</bpmn2:outgoing>
    </bpmn2:task>

    <bpmn2:exclusiveGateway id="Gateway_InStock" name="Item In Stock?">
      <bpmn2:incoming>Flow_2</bpmn2:incoming>
      <bpmn2:outgoing>Flow_InStock</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_OutOfStock</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <bpmn2:task id="Task_ReserveItem" name="Reserve Item">
      <bpmn2:incoming>Flow_InStock</bpmn2:incoming>
      <bpmn2:outgoing>Flow_3</bpmn2:outgoing>
    </bpmn2:task>

    <bpmn2:task id="Task_BackOrder" name="Create Back Order">
      <bpmn2:incoming>Flow_OutOfStock</bpmn2:incoming>
      <bpmn2:outgoing>Flow_4</bpmn2:outgoing>
    </bpmn2:task>

    <bpmn2:task id="Task_ProcessPayment" name="Process Payment">
      <bpmn2:incoming>Flow_3</bpmn2:incoming>
      <bpmn2:outgoing>Flow_5</bpmn2:outgoing>
    </bpmn2:task>

    <bpmn2:task id="Task_PackageItem" name="Package Item">
      <bpmn2:incoming>Flow_5</bpmn2:incoming>
      <bpmn2:outgoing>Flow_6</bpmn2:outgoing>
    </bpmn2:task>

    <bpmn2:task id="Task_ShipOrder" name="Ship Order">
      <bpmn2:incoming>Flow_6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_7</bpmn2:outgoing>
    </bpmn2:task>

    <bpmn2:endEvent id="EndEvent_Shipped" name="Order Shipped">
      <bpmn2:incoming>Flow_7</bpmn2:incoming>
    </bpmn2:endEvent>

    <bpmn2:endEvent id="EndEvent_BackOrdered" name="Back Order Confirmed">
      <bpmn2:incoming>Flow_4</bpmn2:incoming>
    </bpmn2:endEvent>

    <bpmn2:sequenceFlow id="Flow_1"          sourceRef="StartEvent_1"      targetRef="Task_CheckInventory"/>
    <bpmn2:sequenceFlow id="Flow_2"          sourceRef="Task_CheckInventory" targetRef="Gateway_InStock"/>
    <bpmn2:sequenceFlow id="Flow_InStock"    name="Yes" sourceRef="Gateway_InStock" targetRef="Task_ReserveItem"/>
    <bpmn2:sequenceFlow id="Flow_OutOfStock" name="No"  sourceRef="Gateway_InStock" targetRef="Task_BackOrder"/>
    <bpmn2:sequenceFlow id="Flow_3"          sourceRef="Task_ReserveItem"   targetRef="Task_ProcessPayment"/>
    <bpmn2:sequenceFlow id="Flow_4"          sourceRef="Task_BackOrder"     targetRef="EndEvent_BackOrdered"/>
    <bpmn2:sequenceFlow id="Flow_5"          sourceRef="Task_ProcessPayment" targetRef="Task_PackageItem"/>
    <bpmn2:sequenceFlow id="Flow_6"          sourceRef="Task_PackageItem"   targetRef="Task_ShipOrder"/>
    <bpmn2:sequenceFlow id="Flow_7"          sourceRef="Task_ShipOrder"     targetRef="EndEvent_Shipped"/>

  </bpmn2:process>

</bpmn2:definitions>
